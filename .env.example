# .env.example -- Copy to .env and fill in real values
# NEVER commit .env to version control

# --- Retell AI ---
RETELL_API_KEY=your_retell_api_key_here
RETELL_AGENT_ID=your_agent_id_here
RETELL_LLM_ID=your_llm_id_here

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_key_here
SUPABASE_ANON_KEY=your_anon_key_here

# --- Retell Phone Number ---
# Phone number must have outbound_agents configured (run migrate_phone_number.py)
RETELL_PHONE_NUMBER=+17404943597

# --- Twilio (retained for original import reference) ---
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here

# --- Resend (payment emails) ---
RESEND_API_KEY=your_resend_key_here
NOTIFICATION_FROM_EMAIL=sarah@cloudboosta.co.uk

# --- Webhook Backend ---
WEBHOOK_BASE_URL=https://your-endpoint.com
WEBHOOK_SECRET=generate_a_random_32_char_string

# --- Dashboard ---
DASHBOARD_SECRET_KEY=generate_a_random_64_char_string
DASHBOARD_ORIGIN=http://localhost:5173

# --- n8n ---
N8N_BASE_URL=https://your-n8n-instance.com
N8N_API_KEY=your_n8n_api_key_here
N8N_WEBHOOK_SECRET=generate_a_random_32_char_string

# --- Admin ---
ADMIN_EMAIL=your_admin_email_here
